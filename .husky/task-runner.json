{
  "tasks": [
    {
      "name": "format",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["tool", "run", "csharpier", "format", "."],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "style",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["tool", "run", "csharpier", "check", "."],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "analyzers",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format",
        "analyzers",
        "DevSecOpsPipelineSample.slnx",
        "--verify-no-changes"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "build",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "build",
        "DevSecOpsPipelineSample.slnx",
        "--no-restore",
        "--configuration",
        "Release",
        "/warnaserror"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "test",
      "command": "dotnet",
      "args": [
        "test",
        "DevSecOpsPipelineSample.slnx",
        "--configuration",
        "Release",
        "--no-build",
        "--logger",
        "trx",
        "--results-directory",
        "TestResults",
        "--collect:XPlat Code Coverage",
        "--verbosity",
        "minimal"
      ],
      "include": [
        "src/**/*",
        "tests/**/*",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.sln",
        "**/*.slnx"
      ]
    }
  ]
}
