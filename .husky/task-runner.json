{
  "tasks": [
    {
      "name": "format",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["tool", "run", "csharpier", "format", "."],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "style",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["tool", "run", "csharpier", "check", "."],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "analyzers",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format",
        "analyzers",
        "DevSecOpsPipelineSample.slnx",
        "--verify-no-changes"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "setup-solution-restore",
      "command": "bash",
      "args": [
        "-c",
        "dotnet restore \"${SOLUTION_PATH:-DevSecOpsPipelineSample.slnx}\""
      ]
    },
    {
      "name": "build",
      "group": "pre-push",
      "command": "bash",
      "args": [
        "-c",
        "dotnet build \"${SOLUTION_PATH:-DevSecOpsPipelineSample.slnx}\" --configuration \"${BUILD_CONFIGURATION:-Release}\" -warnaserror"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "build-ci",
      "command": "bash",
      "args": [
        "-c",
        "dotnet build \"${SOLUTION_PATH:-DevSecOpsPipelineSample.slnx}\" --no-restore --configuration \"${BUILD_CONFIGURATION:-Release}\" -warnaserror"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ],
      "group": "ci"
    },
    {
      "name": "gitleaks",
      "group": "pre-push",
      "command": "bash",
      "args": [
        "-c",
        "if command -v gitleaks >/dev/null 2>&1; then gitleaks dir --no-banner --redact --verbose .; exit $?; fi; if ! command -v docker >/dev/null 2>&1; then echo \"Gitleaks is not installed locally and Docker is unavailable. Install Gitleaks or Docker Desktop, or bypass the hook intentionally with git push --no-verify.\"; exit 1; fi; docker info >/dev/null 2>&1 || { echo \"Gitleaks is not installed locally and the Docker daemon is not running. Install Gitleaks or start Docker Desktop, then push again.\"; exit 1; }; repo_root=\"$(git rev-parse --show-toplevel)\" && MSYS_NO_PATHCONV=1 docker run --rm -v \"$repo_root:/repo\" -w /repo zricethezav/gitleaks:latest dir --no-banner --redact --verbose ."
      ]
    },
    {
      "name": "test",
      "group": "pre-push",
      "command": "bash",
      "args": ["scripts/run-tests.sh"],
      "include": [
        "src/**/*",
        "tests/**/*",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.sln",
        "**/*.slnx"
      ]
    }
  ]
}
