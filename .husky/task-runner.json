{
  "tasks": [
    {
      "name": "format",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["tool", "run", "csharpier", "format", "."],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "style",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["tool", "run", "csharpier", "check", "."],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "analyzers",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "format",
        "analyzers",
        "DevSecOpsPipelineSample.slnx",
        "--verify-no-changes"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "build",
      "group": "pre-push",
      "command": "dotnet",
      "args": [
        "build",
        "DevSecOpsPipelineSample.slnx",
        "--no-restore",
        "--configuration",
        "Release",
        "/warnaserror"
      ],
      "include": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.editorconfig",
        "**/*.sln",
        "**/*.slnx"
      ]
    },
    {
      "name": "gitleaks",
      "group": "pre-push",
      "command": "sh",
      "args": [
        "-c",
        "repo_root=\"$(git rev-parse --show-toplevel)\" && MSYS_NO_PATHCONV=1 docker run --rm -v \"$repo_root:/repo\" -w /repo zricethezav/gitleaks:latest dir --no-banner --redact --verbose ."
      ]
    },
    {
      "name": "test",
      "group": "pre-push",
      "command": "sh",
      "args": ["scripts/run-tests.sh"],
      "include": [
        "src/**/*",
        "tests/**/*",
        "**/*.csproj",
        "**/*.props",
        "**/*.targets",
        "**/*.sln",
        "**/*.slnx"
      ]
    }
  ]
}
